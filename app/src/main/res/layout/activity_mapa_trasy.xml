<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F2"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="18dp">

        <TextView
            android:id="@+id/btnPowrotMapaTrasy"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:minWidth="72dp"
            android:text="← Powrót"
            android:textColor="#1F3D2B"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTytulMapyTrasy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="Mapa"
            android:textColor="#1F3D2B"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/mapViewTrasy"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginBottom="172dp"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/btnZoomPlus"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_zoom_button_purple"
                android:elevation="8dp"
                android:gravity="center"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnWycentrujMape"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_zoom_button_purple"
                android:elevation="8dp"
                android:gravity="center"
                android:text="◎"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnZoomMinus"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_zoom_button_purple"
                android:elevation="8dp"
                android:gravity="center"
                android:text="−"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="16dp"
            android:background="@drawable/bg_map_status_panel"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/txtStatusMapyTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wczytywanie mapy..."
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnRozpocznijTrase"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_map_action_button"
                android:gravity="center"
                android:text="Rozpocznij trasę"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
