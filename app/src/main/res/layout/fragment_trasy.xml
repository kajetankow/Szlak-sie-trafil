<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/trasyScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/kontenerTrasy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="44dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/txtTrasyTytul"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trasy"
            android:textColor="#111827"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTrasyOpis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Filtruj trasy po regionie, typie, poziomie trudności albo nazwie i zaplanuj własną podróż."
            android:textColor="#4B5563"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/panelFiltry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_route"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtFiltryNaglowek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Filtry tras"
                android:textColor="#111827"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtFiltryOpis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Dodaj filtry, np. Kraków, Tatry, miejska, górska, łatwa. Podpowiedzi są tworzone na podstawie tras zapisanych w bazie."
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:id="@+id/scrollFiltry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/kontenerBloczkowFiltrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputDodajFiltr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Wpisz region, typ, poziom lub nazwę"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtDodajFiltr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/kontenerPodpowiedziFiltrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/panelPrzyciskowFiltrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnDodajFiltr"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dodaj" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnWyczyscFiltry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Wyczyść" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sekcjaMojeTrasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtMojeTrasyNaglowek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Moje trasy"
                android:textColor="#111827"
                android:textSize="19sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/panelPrzyciskowMojeTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnDodajTrase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+ Nowa trasa" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnPokazWszystkieMojeTrasy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pokaż wszystkie" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtBrakMoichTras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_panel_warning"
                android:padding="16dp"
                android:text="To jest czas, aby zacząć planować swoje drogi po swojemu."
                android:textColor="#92400E"
                android:textSize="15sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/kontenerMojeTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btnRozwinMojeTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Rozwiń wszystkie"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sekcjaPunkty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_section_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtPunktyNaglowek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Punkty"
                android:textColor="#111827"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPunktyOpis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Wszystkie punkty zapisane w bazie. Możesz je wyszukać, podejrzeć i zacząć z nich tworzyć trasę."
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/panelPrzyciskowPunktow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnDodajPunkt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Nowy punkt" />

            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputSzukajPunkt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Szukaj punktu po nazwie"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtSzukajPunkt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/txtBrakPunktow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_panel_warning"
                android:padding="16dp"
                android:text="Nie znaleziono punktów."
                android:textColor="#92400E"
                android:textSize="15sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/kontenerPunktow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btnRozwinPunkty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Rozwiń"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtProponowaneNaglowek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Proponowane trasy"
            android:textColor="#111827"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtProponowaneOpis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Lista jest filtrowana na podstawie aktywnych filtrów z górnej sekcji."
            android:textColor="#4B5563"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtBrakProponowanychTras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel_warning"
            android:padding="16dp"
            android:text="Nie znaleziono tras pasujących do aktywnych filtrów."
            android:textColor="#92400E"
            android:textSize="15sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTrasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false" />

        <Button
            android:id="@+id/btnRozwinProponowaneTrasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Rozwiń"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>