<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F2"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="34dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Konto"
            android:textColor="#1F3D2B"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_route"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:id="@+id/txtKontoAvatar"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_zoom_button_purple"
                android:gravity="center"
                android:text="ST"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtKontoTytul"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cześć"
                    android:textColor="#111827"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtKontoOpis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#52635A"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panelKontoLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_route"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zaloguj się"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtKontoLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Email lub telefon"
                android:inputType="textEmailAddress" />

            <Spinner
                android:id="@+id/spinnerKontoKraj"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp" />

            <EditText
                android:id="@+id/edtKontoHaslo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Hasło"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/btnKontoZaloguj"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Zaloguj się" />

            <TextView
                android:id="@+id/txtKontoLinkRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="#4B5563"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnEdytujProfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Edytuj dane profilu" />

        <Button
            android:id="@+id/btnHistoriaTras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Historia tras" />

        <Button
            android:id="@+id/btnAktywnosc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aktywność" />

        <Button
            android:id="@+id/btnWyloguj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E5E7EB"
            android:text="Wyloguj"
            android:textColor="#374151" />

        <Button
            android:id="@+id/btnUsunKonto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#DC2626"
            android:text="Usuń konto"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</ScrollView>
