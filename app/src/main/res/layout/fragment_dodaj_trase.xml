<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/kontenerDodajTrase"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="44dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/txtPowrotDodajTrase"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:text="← Powrót"
        android:textColor="#2563EB"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtDodajTraseTytul"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Zaplanuj trasę"
        android:textColor="#111827"
        android:textSize="30sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/panelKroki"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card_route"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:id="@+id/txtKrok1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1. Dane"
            android:textColor="#2563EB"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtKrok2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="2. Punkty"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtKrok3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="3. Podsumowanie"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelKrokDane"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card_route"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dane podstawowe"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Wpisz nazwę, opis, region i typ trasy. Region centruje mapę w kolejnym kroku i służy do filtrowania."
            android:textColor="#4B5563"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputNazwaNowejTrasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Nazwa trasy"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtNazwaNowejTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputOpisNowejTrasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Opis trasy"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtOpisNowejTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputRegionNowejTrasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Region, np. Kraków, Tatry, Ojców"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtRegionNowejTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Typ trasy"
            android:textColor="#4B5563"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spinnerTypTrasy"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnDalejDoPunktow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dalej" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelKrokPunkty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card_route"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtInstrukcjaPunktow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Najpierw dodaj punkt startu."
            android:textColor="#111827"
            android:textSize="15sp"
            android:textStyle="bold" />

        <org.osmdroid.views.MapView
            android:id="@+id/mapaKreatorTrasy"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="2.2" />

        <TextView
            android:id="@+id/txtParametryRobocze"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Punkty: 0 • Dystans: 0.0 km • Czas: 0 min"
            android:textColor="#2563EB"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputNazwaPunktu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="Nazwa lub współrzędne punktu"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtNazwaPunktu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:includeFontPadding="true"
                android:inputType="text"
                android:singleLine="true"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSzukajDodajPunkt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="40dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Dodaj punkt startu"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTrybMapa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:minHeight="40dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Wybierz punkty z mapy"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnBibliotekaPunktow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:minHeight="40dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Lista i wyszukiwanie punktów"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOptymalizujPunkty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="38dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="Optymalizuj"
                android:textSize="12sp"
                android:visibility="gone" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnUsunOstatniPunkt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="38dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="Usuń ostatni"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtListaPunktow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="58dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_panel_warning"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="Nie dodano jeszcze żadnego punktu."
            android:textColor="#92400E"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnWrocDoDanych"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Wróć"
                android:textSize="12sp" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnDalejDoPodsumowania"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Dalej"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelKrokPodsumowanie"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card_route"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Podsumowanie"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />

        <org.osmdroid.views.MapView
            android:id="@+id/mapaPodsumowanieTrasy"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/txtPodsumowanieTrasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_panel_warning"
            android:padding="10dp"
            android:text="Brak danych do podsumowania."
            android:textColor="#374151"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnDodajMape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dodaj trasę" />

        <Button
            android:id="@+id/btnAnulujKreator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Anuluj" />

        <Button
            android:id="@+id/btnWrocDoPunktow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Wróć do punktów" />
    </LinearLayout>

</LinearLayout>
