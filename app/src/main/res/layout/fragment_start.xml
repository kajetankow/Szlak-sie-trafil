<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/startScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="44dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/txtNazwaAplikacji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Szlak się Trafił!"
            android:textColor="#7C3AED"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPowitanie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Hej, witaj! Dokąd dzisiaj idziemy?"
            android:textColor="#4B5563"
            android:textSize="17sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_section_divider" />

        <LinearLayout
            android:id="@+id/panelNiezalogowany"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_panel_warning"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStatusLogowania"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hej, jesteś niezalogowany"
                android:textColor="#1F2937"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOpisLogowania"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Masz dostęp do ograniczonych funkcjonalności. Zaloguj się, aby zapisywać własne trasy, statystyki, ulubione miejsca i znajomych."
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnZaloguj"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Zaloguj" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnZarejestruj"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Zarejestruj" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_section_panel"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtPolecaneNaglowek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Polecane przykładowe trasy dla lokalizacji:"
                android:textColor="#111827"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtGpsInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ustalamy Twoją lokalizację..."
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_section_divider" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPolecaneTrasy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/txtBrakTras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_panel_warning"
                android:padding="16dp"
                android:text="Nie znaleziono tras w Twojej lokalizacji. Ale nie przejmuj się - zaplanuj swoją trasę!"
                android:textColor="#92400E"
                android:textSize="15sp"
                android:visibility="gone" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_section_divider" />

        <LinearLayout
            android:id="@+id/panelStatystyki"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_route"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStatystykiNaglowek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Statystyki z ostatnich 7 dni"
                android:textColor="#111827"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtStatystykiOpis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Aby zbierać i analizować dane o swoich trasach, zaloguj się."
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnZalogujStatystyki"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Zaloguj się" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
