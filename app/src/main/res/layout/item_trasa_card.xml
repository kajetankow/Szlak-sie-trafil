<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:layout_marginEnd="12dp"
    android:orientation="vertical"
    android:background="@drawable/card_background"
    android:padding="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:gravity="center"
        android:text="TRASA"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/photo_placeholder" />

    <TextView
        android:id="@+id/txtNazwaTrasy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#1F3D2B" />

    <TextView
        android:id="@+id/txtOpisTrasy"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:maxLines="3"
        android:textSize="13sp"
        android:textColor="#4C5D54" />

    <TextView
        android:id="@+id/txtMetaTrasy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#263B30" />

    <TextView
        android:id="@+id/txtTrudnoscTrasy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textSize="12sp"
        android:textColor="#607569" />

    <Button
        android:id="@+id/btnPokazMapeTrasy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pokaż mapę" />

</LinearLayout>
