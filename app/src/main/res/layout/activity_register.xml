<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/registerScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="44dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/txtPowrotRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="← Powrót"
            android:textColor="#2563EB"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtRegisterTytul"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Utwórz konto"
            android:textColor="#111827"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtRegisterOpis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Dołącz do Szlak się Trafił i zapisuj swoje trasy, statystyki oraz ulubione miejsca."
            android:textColor="#4B5563"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/panelRegisterForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_route"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Imię">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtImie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Nazwisko">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtNazwisko"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Wyświetlana nazwa / pseudonim opcjonalnie">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPseudonim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Rok urodzenia">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtRokUrodzenia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="4" />

                </com.google.android.material.textfield.TextInputLayout>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Wzrost cm">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtWzrost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="3" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Waga kg">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtWaga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:maxLength="5" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/txtKontaktNaglowek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Dane kontaktowe"
                android:textColor="#111827"
                android:textSize="17sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioKontakt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radioEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Email" />

                <RadioButton
                    android:id="@+id/radioTelefon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Telefon" />

            </RadioGroup>

            <LinearLayout
                android:id="@+id/panelEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Adres email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtEmailRegister"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelTelefon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kraj numeru telefonu"
                    android:textColor="#4B5563"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/spinnerKraj"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputTelefonLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Numer telefonu">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtTelefonRegister"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:hint="Hasło">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtHasloRegister"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Powtórz hasło">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPowtorzHasloRegister"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />

            </com.google.android.material.textfield.TextInputLayout>

            <CheckBox
                android:id="@+id/checkRegulaminRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Akceptuję regulamin aplikacji"
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtPokazRegulaminRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Pokaż regulamin"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRegulaminRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="1. Aplikacja Szlak się Trafił wspiera planowanie i śledzenie tras.\n\n2. Dane lokalizacyjne są używane wyłącznie do działania mapy, rekomendacji i funkcji związanych z trasami.\n\n3. Trasy oraz rekomendacje mają charakter informacyjny i nie zastępują oceny warunków terenowych.\n\n4. Użytkownik odpowiada za bezpieczeństwo podczas podróży.\n\n5. Kontakt: pomoc@szlaksietrafil.example.com."
                android:textColor="#4B5563"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnRegisterSubmit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Zarejestruj się" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
